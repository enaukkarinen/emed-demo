{
  "name": "emed-demo",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm -r --parallel --stream --reporter append-only dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:build": "docker compose -f docker/docker-compose.yml up -d",
    "kb:ingest": "dotenv -e .env -- tsx packages/kb/scripts/kb-ingest.ts",
    "kb:test": "dotenv -e .env -- tsx packages/kb/scripts/kb-search-test.ts"
  },
  "devDependencies": {
    "@types/node": "20.0.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0"
  }
}
